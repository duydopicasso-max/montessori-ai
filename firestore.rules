rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isParticipant(conv) {
      return request.auth.uid in conv.data.participantIds;
    }

    function isNotBlocked(conv) {
      return !(request.auth.uid in conv.data.blockedBy);
    }

    // ════════════════════════════════════════════════════════
    // PUBLIC COMMUNITY ROOMS
    // ════════════════════════════════════════════════════════

    match /chatRooms/{roomId}/messages/{msgId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000;
      allow update: if isSignedIn()
                    && resource.data.senderId == request.auth.uid;
      allow delete: if false; // No hard deletes by clients
    }

    // ════════════════════════════════════════════════════════
    // CUSTOM ROOMS (user-created)
    // ════════════════════════════════════════════════════════

    match /customRooms/{roomId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.createdBy == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['lastMessageAt', 'messageCount']));
      allow delete: if isSignedIn()
                    && resource.data.createdBy == request.auth.uid;

      match /messages/{msgId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 2000;
        allow update: if isSignedIn()
                      && resource.data.senderId == request.auth.uid;
        allow delete: if false;
      }
    }

    // ════════════════════════════════════════════════════════
    // DM REQUESTS (Phase 1 — lời mời nhắn tin)
    // ════════════════════════════════════════════════════════

    match /dmRequests/{reqId} {
      // Only sender or receiver can read
      allow read: if isSignedIn()
                  && (resource.data.fromUserId == request.auth.uid
                      || resource.data.toUserId == request.auth.uid);

      // Create: must be authenticated, fromUserId must match caller
      allow create: if isSignedIn()
                    && request.resource.data.fromUserId == request.auth.uid
                    && request.resource.data.toUserId != request.auth.uid  // cannot invite yourself
                    && request.resource.data.status == 'pending'
                    && request.resource.data.introMessage is string
                    && request.resource.data.introMessage.size() <= 300;

      // Update: only receiver can accept/decline, only sender can cancel
      allow update: if isSignedIn()
                    && (
                      // Receiver: can only change status to accepted/declined
                      (resource.data.toUserId == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'updatedAt'])
                       && request.resource.data.status in ['accepted', 'declined'])
                      ||
                      // Sender: can cancel (set to blocked/withdrawn)
                      (resource.data.fromUserId == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'updatedAt'])
                       && request.resource.data.status == 'blocked')
                    );

      allow delete: if false; // Soft deletes only (status change)
    }

    // ════════════════════════════════════════════════════════
    // CONVERSATIONS (1-on-1 private chats)
    // ════════════════════════════════════════════════════════

    match /conversations/{convId} {
      // Only participants can read conversation metadata
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participantIds;

      // Create: must be authenticated, participantIds must include caller,
      // and there must be exactly 2 participants
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.participantIds.size() == 2;

      // Update: only participants can update, with restrictions
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participantIds
                    && (
                      // Allowed metadata updates: lastMessage, lastMessageAt, unreadCounts, blockedBy, hiddenFor
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly([
                          'lastMessage', 'lastMessageAt',
                          'unreadCounts', 'blockedBy', 'hiddenFor',
                          'mutedBy', 'updatedAt'
                        ])
                      // Participants cannot change core fields
                      && request.resource.data.participantIds == resource.data.participantIds
                      && request.resource.data.participantData == resource.data.participantData
                    );

      allow delete: if false; // Soft delete via hiddenFor field

      // ── MESSAGES sub-collection ──
      match /messages/{msgId} {
        // Only conversation participants can read messages
        allow read: if isSignedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        // Create: caller must be a participant AND not blocked
        allow create: if isSignedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
                      && !(request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.blockedBy)
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000;

        // Update: sender can soft-delete (add to deletedFor), or mark as read
        allow update: if isSignedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['readBy', 'deletedFor']);

        allow delete: if false; // Soft delete only
      }
    }

    // ════════════════════════════════════════════════════════
    // REPORTS (abuse reports)
    // ════════════════════════════════════════════════════════

    match /reports/{reportId} {
      // Reporter can read their own reports; admins use Firebase Admin SDK
      allow read:   if isSignedIn()
                    && resource.data.reportedBy == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.reportedBy == request.auth.uid
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 100
                    && request.resource.data.status == 'pending';
      allow update: if false; // Only admin can update report status
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════
    // CATCH-ALL: Deny everything else
    // ════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
