rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isParticipant(conv) {
      return request.auth.uid in conv.data.participantIds;
    }

    function isNotBlocked(conv) {
      return !(request.auth.uid in conv.data.blockedBy);
    }

    // isAdmin: reads users/{uid}.role from Firestore
    // NOTE: This is a document-read based check (not custom claims).
    // Upgrade to custom claims via Firebase Admin SDK for higher security if needed.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ════════════════════════════════════════════════════════
    // PUBLIC COMMUNITY ROOMS
    // ════════════════════════════════════════════════════════

    match /chatRooms/{roomId}/messages/{msgId} {
      allow read: if isSignedIn();

      // Regular user post: sender must be self, text capped at 2000 chars
      allow create: if isSignedIn()
                    && !('authorType' in request.resource.data)
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000;

      // Admin AI post: strictly validated, only to whitelisted rooms
      allow create: if isAdmin()
                    && roomId in ['pregnancy', 'weaning', 'sleep', 'health', 'family']
                    && request.resource.data.senderId       == request.auth.uid
                    && request.resource.data.authorType     == 'ai_assistant'
                    && request.resource.data.senderName     is string
                    && request.resource.data.senderName.size() > 0
                    && request.resource.data.isAnon         == false
                    && request.resource.data.text           is string
                    && request.resource.data.text.size()    >  0
                    && request.resource.data.text.size()    <= 5000
                    && request.resource.data.title          is string
                    && request.resource.data.sourceQueueId  is string
                    && request.resource.data.transparencyLabel is string
                    && request.resource.data.likes          == 0
                    && request.resource.data.replies        == 0
                    && request.resource.data.images         is list
                    && request.resource.data.images.size()  <= 1
                    && (
                      request.resource.data.images.size() == 0
                      || (
                        request.resource.data.images[0] is string
                        && request.resource.data.images[0].size() <= 2048
                        && request.resource.data.images[0].matches('^https://.*')
                      )
                    );

      allow update: if isSignedIn()
                    && resource.data.senderId == request.auth.uid;
      allow delete: if false; // No hard deletes by clients
    }

    // ════════════════════════════════════════════════════════
    // CUSTOM ROOMS (user-created)
    // ════════════════════════════════════════════════════════

    match /customRooms/{roomId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.createdBy == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['lastMessageAt', 'messageCount']));
      allow delete: if isSignedIn()
                    && resource.data.createdBy == request.auth.uid;

      match /messages/{msgId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 2000;
        allow update: if isSignedIn()
                      && resource.data.senderId == request.auth.uid;
        allow delete: if false;
      }
    }

    // ════════════════════════════════════════════════════════
    // DM REQUESTS (Phase 1 — lời mời nhắn tin)
    // ════════════════════════════════════════════════════════

    match /dmRequests/{reqId} {
      // List queries: authenticated users can query their own requests
      // (Firestore security rules: collection queries use 'list', doc reads use 'get')
      allow list: if isSignedIn();

      // Single document read: only sender or receiver
      allow get: if isSignedIn()
                  && (resource.data.fromUserId == request.auth.uid
                      || resource.data.toUserId == request.auth.uid);

      // Create: must be authenticated, fromUserId must match caller
      allow create: if isSignedIn()
                    && request.resource.data.fromUserId == request.auth.uid
                    && request.resource.data.toUserId != request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.introMessage is string
                    && request.resource.data.introMessage.size() <= 300;

      // Update: only receiver can accept/decline, only sender can cancel
      allow update: if isSignedIn()
                    && (
                      (resource.data.toUserId == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'updatedAt'])
                       && request.resource.data.status in ['accepted', 'declined'])
                      ||
                      (resource.data.fromUserId == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'updatedAt'])
                       && request.resource.data.status == 'blocked')
                    );

      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════
    // CONVERSATIONS (1-on-1 private chats)
    // ════════════════════════════════════════════════════════

    match /conversations/{convId} {
      // List & get: only participants
      allow list: if isSignedIn();
      allow get:  if isSignedIn()
                  && request.auth.uid in resource.data.participantIds;

      // Create
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.participantIds.size() == 2;

      // Update: only participants, restricted fields
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participantIds
                    && (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly([
                          'lastMessage', 'lastMessageAt',
                          'unreadCounts', 'blockedBy', 'hiddenFor',
                          'mutedBy', 'updatedAt'
                        ])
                      && request.resource.data.participantIds == resource.data.participantIds
                      && request.resource.data.participantData == resource.data.participantData
                    );

      allow delete: if false;

      // ── MESSAGES sub-collection ──
      match /messages/{msgId} {
        // Only conversation participants can read messages
        allow read: if isSignedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        // Create: caller must be a participant AND not blocked
        allow create: if isSignedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
                      && !(request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.blockedBy)
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000;

        // Update: sender can soft-delete (add to deletedFor), or mark as read
        allow update: if isSignedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['readBy', 'deletedFor']);

        allow delete: if false; // Soft delete only
      }
    }

    // ════════════════════════════════════════════════════════
    // REPORTS (abuse reports)
    // ════════════════════════════════════════════════════════

    match /reports/{reportId} {
      // Reporter can read their own reports; admins use Firebase Admin SDK
      allow read:   if isSignedIn()
                    && resource.data.reportedBy == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.reportedBy == request.auth.uid
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 100
                    && request.resource.data.status == 'pending';
      allow update: if false; // Only admin can update report status
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════
    // USERS & THEIR PRIVATE DATA
    // ════════════════════════════════════════════════════════

    match /users/{userId} {
      // Authenticated users can read basic profile details for community views
      allow read: if isSignedIn();

      // 🔒 PROTECTED FIELDS — must never be set by the client SDK.
      // Reserved for Firebase Admin SDK only.
      // Covers: role, isAdmin, admin, claims, permissions, plan, subscription

      // Owner can create their own profile document
      // Block if ANY protected field is present in the written document
      allow create: if isSignedIn() && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny([
                         'role', 'isAdmin', 'admin',
                         'claims', 'permissions',
                         'plan', 'subscription'
                       ]);

      // Owner can update their own profile
      // Block if the incoming document contains ANY protected field
      // (covers both changed fields AND newly added fields)
      // 🔒 NOTE: we check request.resource.data.keys() — the full outgoing doc —
      //          NOT just affectedKeys(), which only detects changed values.
      allow update: if isSignedIn() && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny([
                         'role', 'isAdmin', 'admin',
                         'claims', 'permissions',
                         'plan', 'subscription'
                       ]);

      // Owner can delete their own profile document
      allow delete: if isSignedIn() && request.auth.uid == userId;

      // Owner private subcollections (babies, pregnancyVisits, moments, reminders, etc.)
      match /{privateData=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /blockedUsers/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ════════════════════════════════════════════════════════
    // AI CONTENT REVIEW QUEUE (admin-only, never public)
    // ════════════════════════════════════════════════════════
    // Items imported here have reviewStatus: 'pending_review'.
    // They are NEVER automatically promoted to community posts.
    // Regular users have NO read or write access to this collection.

    match /aiContentReviewQueue/{itemId} {
      // Only admins can read items in the review queue
      allow read: if isAdmin();

      // Only admins can create items; enforce safety invariants
      allow create: if isAdmin()
                    && request.resource.data.reviewStatus  == 'pending_review'
                    && request.resource.data.importedByUid == request.auth.uid
                    && request.resource.data.authorType    == 'ai_assistant';

      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly([
                         // Review fields
                         'reviewStatus', 'reviewedAt', 'reviewedByUid',
                         'reviewNotes', 'updatedAt',
                         // Publish fields (Phase 2C.2)
                         'publishStatus', 'publishedAt', 'publishedByUid',
                         'publishedPostId',
                         // Image fields (Phase 2C.3B)
                         'imageUrl'
                       ])
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewStatus'])
                        || request.resource.data.reviewStatus in [
                             'pending_review', 'needs_edit',
                             'approved_for_publish', 'rejected'
                           ])
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewedByUid'])
                        || request.resource.data.reviewedByUid == request.auth.uid)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['publishStatus'])
                        || request.resource.data.publishStatus in ['published', 'unpublished'])
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['publishedByUid'])
                        || request.resource.data.publishedByUid == request.auth.uid)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['publishedPostId'])
                        || request.resource.data.publishedPostId is string)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['imageUrl'])
                        || (
                          request.resource.data.imageUrl is string
                          && (
                            request.resource.data.imageUrl == ""
                            || (
                              request.resource.data.imageUrl.size() <= 2048
                              && request.resource.data.imageUrl.matches('^https://.*')
                            )
                          )
                        ));

      // Hard deletes allowed only by admin (e.g. discard rejected items)
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════════
    // CATCH-ALL: Deny everything else
    // ════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
