# Montessori RAG Backend — Environment Variables
# Copy file này thành .env và điền giá trị thật

# Google Gemini API Key
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone API Key
# Lấy tại: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone Index Name
PINECONE_INDEX_NAME=montessori-v2

# Server Port (Railway tự set, không cần thay đổi)
PORT=3001

# Frontend URL (set sau khi deploy Vercel)
# Ví dụ: https://montessori-ai.vercel.app
FRONTEND_URL=
